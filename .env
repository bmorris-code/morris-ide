# Clerk Authentication (get real key from https://dashboard.clerk.com)
# Add your key to .env.local: VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_real_key_here

# AI Providers - Replace with your actual API keys
# Get your keys at:
# - Groq: https://console.groq.com/keys
# - Moonshot: https://platform.moonshot.cn
# - OpenAI: https://platform.openai.com/api-keys
# - DeepSeek: https://platform.deepseek.com/api_keys

# Uncomment and replace ONE of these with your actual API key:
# VITE_GROQ_API_KEY=gsk_your_actual_groq_api_key_here
# VITE_MOONSHOT_API_KEY=sk-your_actual_moonshot_api_key_here  
# VITE_OPENAI_API_KEY=sk-your_actual_openai_api_key_here
# VITE_DEEPSEEK_API_KEY=sk-your_actual_deepseek_api_key_here

# Demo: Uncomment one of these lines with a real API key to fix the connection error:
# VITE_GROQ_API_KEY=gsk_demo_key_replace_with_real_key_at_least_20_chars
# VITE_MOONSHOT_API_KEY=sk-demo_key_replace_with_real_key_at_least_20_chars  
# VITE_OPENAI_API_KEY=sk-demo_key_replace_with_real_key_at_least_20_chars
# VITE_DEEPSEEK_API_KEY=sk-demo_key_replace_with_real_key_at_least_20_chars

# Optional: Default AI Provider (groq, moonshot, openai, deepseek)
VITE_DEFAULT_AI_PROVIDER=moonshot

# Optional: Default Model
VITE_DEFAULT_AI_MODEL=kimi-k2-6
