{
  "name": "morris-ide",
  "private": true,
  "version": "1.0.0",
  "description": "AI-Native Secure Development Environment",
  "author": "Morris IDE Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/morris-ide/morris-ide.git"
  },
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "build:electron": "npm run build && npm run electron:compile",
    "electron:compile": "tsc -p tsconfig.electron.json && move /Y dist-electron\\main.js dist-electron\\main.cjs && move /Y dist-electron\\preload.js dist-electron\\preload.cjs",
    "electron:start": "electron .",
    "electron:build": "npm run build:electron && electron-builder",
    "electron:build:win": "npm run build:electron && electron-builder --win",
    "electron:build:mac": "npm run build:electron && electron-builder --mac",
    "electron:build:linux": "npm run build:electron && electron-builder --linux",
    "electron:build:all": "npm run build:electron && electron-builder -mwl",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.6",
    "@monaco-editor/react": "^4.7.0",
    "axios": "^1.15.2",
    "chokidar": "^5.0.0",
    "crypto-js": "^4.2.0",
    "diff-match-patch": "^1.0.5",
    "groq-sdk": "^0.8.0",
    "lucide-react": "^0.400.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "react-syntax-highlighter": "^16.1.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.12",
    "tailwindcss": "3.4.17",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.4.18",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.morriside.app",
    "productName": "Morris IDE",
    "copyright": "Copyright © 2026 Morris IDE",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "artifactName": "MorrisIDE-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Morris IDE"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "artifactName": "MorrisIDE-${version}.${ext}",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png",
      "artifactName": "MorrisIDE-${version}.${ext}",
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release",
      "private": true
    }
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "electron"
    ]
  }
}
